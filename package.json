{
  "name": "voxai-translator",
  "private": true,
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "dev:backend": "powershell -NoExit -Command \"Set-Location ./backend/API; python -m uvicorn main:app --host 127.0.0.1 --port 8000 --reload\"",
    "dev:frontend": "powershell -NoExit -Command \"Set-Location ./ai-translator-frontend; npm run dev\"",
    "dev": "powershell -ExecutionPolicy Bypass -File ./start.ps1"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "react-router-dom": "^7.11.0"
  }
}
